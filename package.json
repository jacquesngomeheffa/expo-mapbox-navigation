{
  "name": "@jacques_gordon/expo-mapbox-navigation",
  "version": "2.3.3",
  "description": "Expo module for Mapbox Navigation SDK with 16KB page size support, NDK27, and Mapbox Maps v11.11.0+",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf build",
    "lint": "tsc --noEmit",
    "test": "echo \"Tests require a full Expo project with EAS Build. See README.\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "expo",
    "mapbox",
    "navigation",
    "react-native",
    "maps",
    "directions",
    "16kb-page-size",
    "ndk27"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jacquesngomeheffa/expo-mapbox-navigation.git"
  },
  "bugs": {
    "url": "https://github.com/jacquesngomeheffa/expo-mapbox-navigation/issues"
  },
  "author": "Jacques Gordon",
  "license": "MIT",
  "homepage": "https://github.com/jacquesngomeheffa/expo-mapbox-navigation#readme",
  "peerDependencies": {
    "expo": ">=53.0.0",
    "react": "*",
    "react-native": "*",
    "@rnmapbox/maps": ">=10.1.0"
  },
  "devDependencies": {
    "expo-module-scripts": "^3.5.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "expo-modules-core": ">=2.0.0"
  },
  "expo": {
    "fyi": "https://github.com/jacques_gordon/expo-mapbox-navigation"
  },
  "files": [
    "android",
    "ios",
    "src",
    "build",
    "plugin",
    "*.podspec",
    "app.plugin.js",
    "expo-module.config.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}