{
  "compilerOptions": {
    "target": "ES2018",
    "module": "CommonJS",
    "lib": ["ES2018"],
    "jsx": "react-native",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationDir": "./build",
    "outDir": "./build",
    "rootDir": "./src"
  },
  "include": ["src"],
  "exclude": ["node_modules", "build"]
}
